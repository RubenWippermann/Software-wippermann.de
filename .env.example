# Keine echten Zugangsdaten in diese Datei eintragen.
APP_BASE_URL=https://software-wippermann.de

# SHA-256-Hash der E-Mail-Adresse des ersten Hauptadministrators.
# Wird nur bei der einmaligen Ersteinrichtung verwendet.
BOOTSTRAP_ADMIN_EMAIL_SHA256=

# Anmeldung und Mehrfaktor-Schutz werden von der Hosting-Plattform bereitgestellt.
# SMS kann später ergänzend als Wiederherstellungsweg angebunden werden.
SMS_PROVIDER=
SMS_API_KEY=
SMS_SENDER=
